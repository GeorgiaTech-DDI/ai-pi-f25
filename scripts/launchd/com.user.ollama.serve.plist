<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.ollama.serve</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/ollama</string>
        <string>serve</string>
    </array>
    <key>RunAtLoad</key>
    <true />
    <key>KeepAlive</key>
    <true />
    <key>StandardOutPath</key>
    <string>/Users/oupadhyay/Library/Logs/ollama.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/oupadhyay/Library/Logs/ollama.log</string>
    <key>ProcessType</key>
    <string
        >Background</string> <!-- Or Interactive if needed, but Background is usually suitable -->
</dict>
</plist>
